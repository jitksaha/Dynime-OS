{
  "name": "dynime-workers",
  "version": "1.0.0",
  "private": true,
  "description": "Cloudflare Workers that replace Supabase (auth, functions gateway, data API, realtime) for Dynime OS.",
  "type": "module",
  "scripts": {
    "dev": "wrangler dev --config ../cloudflare/wrangler.toml",
    "deploy": "wrangler deploy --config ../cloudflare/wrangler.toml",
    "deploy:staging": "wrangler deploy --env staging --config ../cloudflare/wrangler.toml",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "jose": "^5.9.6",
    "postgres": "^3.4.4"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20240925.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^26.0.0",
    "typescript": "^5.6.2",
    "wrangler": "^3.78.0"
  }
}
